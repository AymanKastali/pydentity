{
  "name": "pydentity",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "initializeCommand": "docker network create pydentity 2>/dev/null || true",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--network=pydentity"
  ],
  "mounts": [
    "source=pydentity-venv,target=${containerWorkspaceFolder}/.venv,type=volume"
  ],
  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "postCreateCommand": "sudo chown -R vscode:vscode .venv && make setup",
  "customizations": {
    "vscode": {
      "settings": {
        "python.terminal.useEnvFile": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "streetsidesoftware.code-spell-checker",
        "ms-python.mypy-type-checker",
        "mhutchie.git-graph",
        "eamodio.gitlens",
        "tamasfe.even-better-toml",
        "usernamehw.errorlens",
        "ms-azuretools.vscode-docker",
        "jebbs.plantuml",
        "continue.continue",
        "cweijan.vscode-database-client2"
      ]
    }
  }
}
