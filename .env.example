# ── PostgreSQL ────────────────────────────────────────────────────────
PYDENTITY_POSTGRES__DSN=postgresql+asyncpg://user:pass@host:5432/dbname
PYDENTITY_POSTGRES__ECHO=false           # true = log all SQL queries (dev only)
PYDENTITY_POSTGRES__POOL_SIZE=20         # max persistent connections
PYDENTITY_POSTGRES__MAX_OVERFLOW=30      # extra connections beyond pool_size
PYDENTITY_POSTGRES__POOL_RECYCLE=1800    # recycle connections after N seconds

# ── Security ──────────────────────────────────────────────────────────
PYDENTITY_SECURITY__JWT_KEY_DIRECTORY=keys/    # directory containing RSA private key PEM files
PYDENTITY_SECURITY__EMAIL_VERIFICATION_ON_REGISTER_REQUIRED=true   # require email verification on registration
PYDENTITY_SECURITY__EMAIL_VERIFICATION_ON_CHANGE_REQUIRED=true     # require re-verification when user changes email
PYDENTITY_SECURITY__TOKEN_ISSUER=pydentity                 # JWT "iss" claim value
PYDENTITY_SECURITY__TOKEN_AUDIENCES=["pydentity"]          # JWT "aud" claim values (JSON list)
PYDENTITY_SECURITY__ACCESS_TOKEN_TTL_SECONDS=900           # 15 minutes
PYDENTITY_SECURITY__REFRESH_TOKEN_TTL_SECONDS=604800       # 7 days
PYDENTITY_SECURITY__SESSION_ABSOLUTE_TTL_SECONDS=2592000   # 30 days
PYDENTITY_SECURITY__EMAIL_VERIFICATION_TTL_HOURS=24        # email verification link expiry
PYDENTITY_SECURITY__RESET_TOKEN_TTL_HOURS=1                # password reset link expiry
PYDENTITY_SECURITY__PASSWORD_MIN_LENGTH=8
PYDENTITY_SECURITY__PASSWORD_REQUIRE_UPPERCASE=true
PYDENTITY_SECURITY__PASSWORD_REQUIRE_LOWERCASE=true
PYDENTITY_SECURITY__PASSWORD_REQUIRE_DIGIT=true
PYDENTITY_SECURITY__PASSWORD_REQUIRE_SPECIAL=false
PYDENTITY_SECURITY__PASSWORD_HISTORY_SIZE=3                # reject last N passwords on change
PYDENTITY_SECURITY__LOCKOUT_MAX_ATTEMPTS=5                 # failed logins before lockout
PYDENTITY_SECURITY__LOCKOUT_DURATION_MINUTES=15
PYDENTITY_SECURITY__MAX_DEVICES_PER_USER=3

# ── SMTP ─────────────────────────────────────────────────────────────
PYDENTITY_SMTP__HOST=mailhog       # Docker service name; use localhost for local dev
PYDENTITY_SMTP__PORT=1025          # 1025 for MailHog; 587 for STARTTLS; 465 for TLS
PYDENTITY_SMTP__USERNAME=          # optional
PYDENTITY_SMTP__PASSWORD=          # optional
PYDENTITY_SMTP__USE_TLS=false      # true for port 465
PYDENTITY_SMTP__USE_STARTTLS=false # true for port 587
PYDENTITY_SMTP__SENDER=noreply@localhost
PYDENTITY_SMTP__SENDER_NAME=Pydentity

# ── Redis ────────────────────────────────────────────────────────────
PYDENTITY_REDIS__URL=redis://redis:6379/0           # Docker service name
PYDENTITY_REDIS__EVENT_CHANNEL=pydentity:domain_events

# ── FastAPI ──────────────────────────────────────────────────────────
PYDENTITY_FASTAPI__HOST=0.0.0.0         # bind address
PYDENTITY_FASTAPI__PORT=8000            # bind port
PYDENTITY_FASTAPI__IS_PRODUCTION=false  # true = no reload, false = reload enabled

# ── Middleware ──────────────────────────────────────────────────────
PYDENTITY_MIDDLEWARE__CORS__ALLOWED_ORIGINS=["http://localhost:3000"]  # must match frontend URL; ["*"] rejected when credentials=true
PYDENTITY_MIDDLEWARE__TRUSTED_HOST__ALLOWED_HOSTS=["*"]               # restrict in production (e.g. ["api.example.com"])
PYDENTITY_MIDDLEWARE__RATE_LIMIT__ENABLED=true                        # false to disable during load testing
PYDENTITY_MIDDLEWARE__RATE_LIMIT__TRUST_PROXY=false                   # true if behind a reverse proxy (uses X-Forwarded-For)
PYDENTITY_MIDDLEWARE__RATE_LIMIT__GENERAL_LIMIT=100                   # requests per window (general)
PYDENTITY_MIDDLEWARE__RATE_LIMIT__GENERAL_WINDOW_SECONDS=60
PYDENTITY_MIDDLEWARE__RATE_LIMIT__AUTH_LIMIT=10                       # requests per window (auth endpoints)
PYDENTITY_MIDDLEWARE__RATE_LIMIT__AUTH_WINDOW_SECONDS=60

# ── Logging ──────────────────────────────────────────────────────────
PYDENTITY_LOGGING__LEVEL=debug        # debug, info, warning, error
PYDENTITY_LOGGING__JSON_FORMAT=false  # false = rich colored dev, true = structured JSON prod

# ── Super Admin (optional — omit both to skip seeding, remove after first deploy) ──
PYDENTITY_SUPER_ADMIN__EMAIL=admin@example.com
PYDENTITY_SUPER_ADMIN__PASSWORD=    # required when EMAIL is set
