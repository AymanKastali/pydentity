# ── FastAPI ────────────────────────────────────────────────────────────
PYDENTITY_FASTAPI__APP_NAME=pydentity
PYDENTITY_FASTAPI__APP_VERSION=0.1.0
PYDENTITY_FASTAPI__HOST=0.0.0.0
PYDENTITY_FASTAPI__PORT=8000
PYDENTITY_FASTAPI__RELOAD=true
PYDENTITY_FASTAPI__LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────
PYDENTITY_POSTGRES__DSN=postgresql+asyncpg://pydentity:pydentity@localhost:5432/pydentity
PYDENTITY_POSTGRES__POOL_SIZE=5
PYDENTITY_POSTGRES__MAX_OVERFLOW=10
PYDENTITY_POSTGRES__POOL_RECYCLE=1800
PYDENTITY_POSTGRES__ECHO=false

# ── Security ──────────────────────────────────────────────────────────
PYDENTITY_SECURITY__JWT_SECRET=  # required — no default, must be set
PYDENTITY_SECURITY__JWT_ALGORITHM=HS256
PYDENTITY_SECURITY__TOKEN_ISSUER=pydentity

# ── SMTP (Mailhog in dev) ────────────────────────────────────────────
PYDENTITY_SMTP__HOST=localhost
PYDENTITY_SMTP__PORT=1025
