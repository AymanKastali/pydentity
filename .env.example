# ── PostgreSQL ────────────────────────────────────────────────────────
PYDENTITY_POSTGRES__DSN=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Security ──────────────────────────────────────────────────────────
PYDENTITY_SECURITY__JWT_SECRET=    # required

# ── SMTP ─────────────────────────────────────────────────────────────
PYDENTITY_SMTP__HOST=mailhog       # Docker service name; use localhost for local dev
PYDENTITY_SMTP__PORT=1025          # 1025 for MailHog; 587 for STARTTLS; 465 for TLS
PYDENTITY_SMTP__USERNAME=          # optional
PYDENTITY_SMTP__PASSWORD=          # optional
PYDENTITY_SMTP__USE_TLS=false      # true for port 465
PYDENTITY_SMTP__USE_STARTTLS=false # true for port 587
PYDENTITY_SMTP__SENDER=noreply@localhost
PYDENTITY_SMTP__SENDER_NAME=Pydentity

# ── Redis ────────────────────────────────────────────────────────────
PYDENTITY_REDIS__URL=redis://redis:6379/0           # Docker service name
PYDENTITY_REDIS__EVENT_CHANNEL=pydentity:domain_events

# ── Environment ──────────────────────────────────────────────────────
PYDENTITY_FASTAPI__IS_PRODUCTION=false  # true = no reload, false = reload enabled

# ── Logging ──────────────────────────────────────────────────────────
PYDENTITY_LOGGING__LEVEL=debug        # debug, info, warning, error
PYDENTITY_LOGGING__JSON_FORMAT=false  # false = rich colored dev, true = structured JSON prod

# ── Super Admin (optional — only needed for first deploy, remove after) ──
PYDENTITY_SUPER_ADMIN__EMAIL=admin@example.com
PYDENTITY_SUPER_ADMIN__PASSWORD=    # optional, set only for initial seeding
